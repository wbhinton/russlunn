---
import { Facebook, Twitter, Instagram, Mail } from "@lucide/astro";
---

<footer class="bg-slate-900 text-white pt-20 pb-10">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div
			class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-16 mb-20"
		>
			<!-- Campaign Info -->
			<div class="col-span-1 lg:col-span-1">
				<div class="flex flex-col leading-tight mb-8">
					<span
						class="text-3xl font-black text-white tracking-tighter font-serif"
						>RUSS LUNN</span
					>
					<span
						class="text-[0.7rem] font-bold text-accent tracking-[0.2em] uppercase"
						>Macon County Commissioner</span
					>
				</div>
				<p class="text-slate-400 text-sm leading-relaxed mb-8">
					Building a sustainable, transparent, and prosperous future
					for every family in Macon County. Join us in making a
					difference.
				</p>
				<div class="flex space-x-5">
					<a
						href="#"
						class="text-slate-400 hover:text-white transition-colors"
						aria-label="Facebook"
					>
						<Facebook class="w-6 h-6" />
					</a>
					<a
						href="#"
						class="text-slate-400 hover:text-white transition-colors"
						aria-label="Twitter"
					>
						<Twitter class="w-6 h-6" />
					</a>
					<a
						href="#"
						class="text-slate-400 hover:text-white transition-colors"
						aria-label="Instagram"
					>
						<Instagram class="w-6 h-6" />
					</a>
				</div>
			</div>

			<!-- Quick Links -->
			<div class="col-span-1">
				<h4 class="text-lg font-bold mb-8">Quick Links</h4>
				<ul class="space-y-4">
					<li>
						<a
							href="/about"
							class="text-slate-400 hover:text-white transition-colors text-sm"
							>About Russ</a
						>
					</li>
					<li>
						<a
							href="/#issues"
							class="text-slate-400 hover:text-white transition-colors text-sm"
							>Campaign Issues</a
						>
					</li>
					<li>
						<a
							href="/volunteer"
							class="text-slate-400 hover:text-white transition-colors text-sm"
							>Get Involved</a
						>
					</li>
					<li>
						<a
							href="/privacy"
							class="text-slate-400 hover:text-white transition-colors text-sm"
							>Privacy Policy</a
						>
					</li>
					<li>
						<a
							href="/rules"
							class="text-slate-400 hover:text-white transition-colors text-sm"
							>Contributor Rules</a
						>
					</li>
				</ul>
			</div>

			<!-- Join the Movement -->
			<div class="col-span-1 lg:col-span-2">
				<h4
					class="text-lg font-bold mb-8 uppercase tracking-wider text-accent font-serif"
				>
					Join the Movement
				</h4>
				<p class="text-slate-400 text-sm mb-8">
					Stay updated with our latest news and events. Together, we
					can build a better Macon County.
				</p>
				<form class="flex flex-col sm:flex-row gap-4">
					<div class="relative flex-grow">
						<div
							class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none"
						>
							<Mail class="h-5 w-5 text-slate-500" />
						</div>
						<input
							type="email"
							placeholder="Your email address"
							class="block w-full pl-12 pr-4 py-4 bg-slate-800 border border-slate-700 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-primary-green focus:border-transparent transition-all"
							required
						/>
					</div>
					<button
						type="submit"
						class="bg-accent hover:opacity-90 text-white font-bold py-4 px-8 rounded-md transition-all shadow-lg uppercase tracking-widest text-sm"
					>
						SIGN UP
					</button>
				</form>
			</div>
		</div>

		<!-- NC Compliance & Legal -->
		<div class="border-t border-slate-800 pt-10 mt-10">
			<div
				class="flex flex-col lg:flex-row justify-between items-center gap-10"
			>
				<div class="border-2 border-slate-700 px-8 py-4 inline-block">
					<p
						class="text-[0.65rem] font-bold uppercase tracking-widest text-slate-300"
					>
						Paid for by the Committee to Elect Russ Lunn
					</p>
				</div>
				<div
					class="text-slate-500 text-[0.7rem] max-w-2xl text-center lg:text-right"
				>
					<p class="mb-3">
						Contributions or gifts to the Committee to Elect Russ
						Lunn are not deductible as charitable contributions for
						Federal income tax purposes. North Carolina law
						prohibits contributions from corporations and business
						entities.
					</p>
					<p>
						&copy; {new Date().getFullYear()} Russ Lunn for Macon County
						Commissioner. All rights reserved.
					</p>
				</div>
			</div>
		</div>
	</div>
</footer>
