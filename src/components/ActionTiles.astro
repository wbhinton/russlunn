---
import { ClipboardCheck, MapPin, Calendar, FileText } from "@lucide/astro";

const tiles = [
    {
        title: "Voter Registration",
        icon: ClipboardCheck,
        description: "Check your status or register to vote in NC.",
        href: "https://www.ncsbe.gov/registering/how-register",
    },
    {
        title: "Key Issues",
        icon: FileText,
        description: "Learn about our vision for Macon County.",
        href: "/#issues",
    },
    {
        title: "Find Your Polling Place",
        icon: MapPin,
        description: "Locate your precinct and voting station.",
        href: "https://vt.ncsbe.gov/pplkup/",
    },
    {
        title: "Important Dates",
        icon: Calendar,
        description: "Never miss an election deadline or event.",
        href: "https://www.ncsbe.gov/voting/upcoming-election",
    },
];
---

<section class="py-12 bg-white relative -mt-10 z-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            {
                tiles.map((tile) => (
                    <a
                        href={tile.href}
                        class="bg-white p-8 border-2 border-slate-50 shadow-xl hover:shadow-2xl transition-all group flex flex-col items-center text-center transform hover:-translate-y-1"
                    >
                        <div class="bg-primary/5 p-4 rounded-full mb-6 group-hover:bg-primary group-hover:text-white transition-colors">
                            <tile.icon class="w-8 h-8 text-primary group-hover:text-white" />
                        </div>
                        <h3 class="text-xl font-bold font-serif text-primary mb-3 uppercase tracking-tight">
                            {tile.title}
                        </h3>
                        <p class="text-sm text-slate-500 font-medium leading-relaxed">
                            {tile.description}
                        </p>
                    </a>
                ))
            }
        </div>
    </div>
</section>
