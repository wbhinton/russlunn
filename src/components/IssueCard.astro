---
import * as Icons from '@lucide/astro';

interface Props {
	title: string;
	description: string;
	icon: string;
	href: string;
}

const { title, description, icon, href } = Astro.props;
// @ts-ignore - dynamic icon loading
const IconComponent = Icons[icon] || Icons.HelpCircle;
---

<div
	class="bg-white p-8 rounded-2xl shadow-sm border border-slate-100 flex flex-col h-full hover:shadow-md transition-all group"
>
	<div
		class="bg-primary-green/10 p-4 rounded-xl w-fit mb-6 group-hover:bg-primary-green/20 transition-colors"
	>
		<IconComponent class="w-8 h-8 text-primary-green" />
	</div>
	<h3 class="text-2xl font-bold text-slate-900 mb-3">{title}</h3>
	<p class="text-slate-600 mb-6 flex-grow leading-relaxed">{description}</p>
	<a
		href={href}
		class="text-primary-green font-bold inline-flex items-center group-hover:translate-x-1 transition-transform"
	>
		Read More
		<Icons.ChevronRight class="w-5 h-5 ml-1" />
	</a>
</div>
