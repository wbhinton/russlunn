---
import * as Icons from "@lucide/astro";

interface Props {
	title: string;
	description: string;
	icon: string;
}

const { title, description, icon } = Astro.props;
// @ts-ignore - dynamic icon loading
const IconComponent = Icons[icon] || Icons.HelpCircle;
---

<div
	class="bg-white p-8 rounded-2xl shadow-sm border border-slate-100 flex flex-col h-full hover:shadow-md transition-all group"
>
	<div
		class="bg-primary/5 p-4 rounded-md w-fit mb-6 group-hover:bg-primary group-hover:text-white transition-all"
	>
		<IconComponent class="w-8 h-8 text-primary group-hover:text-white" />
	</div>
	<h3
		class="text-2xl font-bold text-slate-900 mb-3 font-serif uppercase tracking-tight"
	>
		{title}
	</h3>
	<p class="text-slate-600 mb-2 flex-grow leading-relaxed">{description}</p>
</div>
