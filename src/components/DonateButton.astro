---
interface Props {
	class?: string;
}

const { class: className } = Astro.props;
---

<a
	href="/donate"
	class:list={[
		"inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-bold rounded-md text-white bg-primary-blue hover:bg-blue-800 transition-colors shadow-md transform hover:scale-105",
		className,
	]}
>
	DONATE
</a>
