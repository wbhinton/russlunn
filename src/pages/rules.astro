---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contributor Rules | Russ Lunn for Macon County">
    <div class="pt-32 pb-20 bg-primary text-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h1 class="text-5xl md:text-7xl font-bold font-serif mb-6">Contributor Rules</h1>
            <p class="text-xl text-blue-50 max-w-3xl opacity-90 leading-relaxed uppercase tracking-widest font-bold">
                North Carolina Campaign Finance Regulations
            </p>
        </div>
    </div>

    <section class="py-24 bg-white">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="bg-slate-50 p-10 md:p-16 rounded-3xl border border-slate-200">
                <div class="prose prose-lg text-slate-600 max-w-none">
                    <h2 class="text-3xl font-bold text-slate-900 mb-8 font-serif">Legal Requirements for Contributions</h2>
                    <p class="mb-8 font-bold text-slate-900">
                        In order to make a contribution to the Committee to Elect Russ Lunn, you must confirm that the following statements are true and accurate:
                    </p>

                    <ul class="space-y-6 list-none pl-0">
                        <li class="flex items-start gap-4">
                            <span class="flex-shrink-0 w-6 h-6 rounded-full bg-accent flex items-center justify-center text-white text-xs font-bold">1</span>
                            <span>I am a United States citizen or a lawfully admitted permanent resident (i.e., green card holder).</span>
                        </li>
                        <li class="flex items-start gap-4">
                            <span class="flex-shrink-0 w-6 h-6 rounded-full bg-accent flex items-center justify-center text-white text-xs font-bold">2</span>
                            <span>This contribution is made from my own funds, and funds are not being provided to me by another person or entity for the purpose of making this contribution.</span>
                        </li>
                        <li class="flex items-start gap-4">
                            <span class="flex-shrink-0 w-6 h-6 rounded-full bg-accent flex items-center justify-center text-white text-xs font-bold">3</span>
                            <span>I am at least eighteen years old.</span>
                        </li>
                        <li class="flex items-start gap-4">
                            <span class="flex-shrink-0 w-6 h-6 rounded-full bg-accent flex items-center justify-center text-white text-xs font-bold">4</span>
                            <span>I am making this contribution with my own personal credit card and not with a corporate or business card or a card issued to another person.</span>
                        </li>
                        <li class="flex items-start gap-4">
                            <span class="flex-shrink-0 w-6 h-6 rounded-full bg-accent flex items-center justify-center text-white text-xs font-bold">5</span>
                            <span>I am not a federal contractor or a corporation, business entity, or labor union.</span>
                        </li>
                    </ul>

                    <div class="mt-16 p-8 bg-white border border-slate-200 rounded-2xl shadow-sm">
                        <h3 class="text-xl font-bold text-slate-900 mb-4">Contribution Limits</h3>
                        <p class="text-sm leading-relaxed">
                            Under North Carolina law, individual contributions are limited to <strong>$6,400 per election</strong>. Contributions from corporations, business entities, and labor unions are strictly prohibited.
                        </p>
                    </div>

                    <p class="mt-12 text-sm text-slate-400 italic">
                        Contributions or gifts to the Committee to Elect Russ Lunn are not deductible as charitable contributions for Federal income tax purposes.
                    </p>
                </div>
            </div>
        </div>
    </section>
</Layout>
