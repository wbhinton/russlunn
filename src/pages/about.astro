---
import Layout from "../layouts/Layout.astro";
import { User, Award, Heart } from "@lucide/astro";
---

<Layout title="About Russ Lunn | Macon County Commissioner">
	<div class="pt-32 pb-20 bg-primary text-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<h1 class="text-5xl md:text-7xl font-bold font-serif mb-6">About Russ Lunn</h1>
			<p class="text-xl md:text-2xl text-blue-50 max-w-3xl opacity-90 leading-relaxed">
				Dedicated to serving Macon County with transparency, integrity, and a vision for a sustainable future.
			</p>
		</div>
	</div>

	<section class="py-24 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
				<div>
					<div class="prose prose-lg text-slate-600 max-w-none">
						<h2 class="text-3xl font-bold text-slate-900 mb-6 font-serif uppercase tracking-tight">My Journey</h2>
						<p class="mb-6">
							[Placeholder: Insert Russ's personal background, including his connection to Macon County, his professional experience, and his family life.]
						</p>
						<p class="mb-6">
							Russ has spent years working in [Industry/Field], where he learned the importance of [Key Skill/Value]. His deep roots in Western North Carolina have shaped his understanding of the unique challenges and opportunities facing our community today.
						</p>
						
						<h3 class="text-2xl font-bold text-slate-900 mt-12 mb-6 font-serif">Why I'm Running</h3>
						<p>
							[Placeholder: Insert Russ's motivation for running for Macon County Commissioner. Focus on key themes like sustainability, transparency, and prosperity for all families.]
						</p>
					</div>
				</div>
				<div class="relative">
					<div class="aspect-[4/5] bg-slate-200 rounded-3xl overflow-hidden shadow-2xl skew-y-1">
						<!-- Placeholder for Bio Photo -->
						<div class="absolute inset-0 flex items-center justify-center text-slate-500 font-bold uppercase tracking-widest text-sm">
							Bio Photo Placeholder
						</div>
					</div>
					<div class="absolute -bottom-8 -left-8 bg-accent p-8 rounded-2xl shadow-xl hidden md:block">
						<p class="text-white font-bold text-lg italic">"A Voice for Every Corner of Macon County."</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="py-24 bg-slate-50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-16">
				<h2 class="text-4xl font-bold text-slate-900 font-serif mb-4">Values & Experience</h2>
				<p class="text-lg text-slate-600 max-w-2xl mx-auto">Foundational principles that guide Russ's leadership.</p>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-12">
				<div class="bg-white p-10 rounded-2xl shadow-sm border border-slate-100">
					<div class="bg-primary/5 p-4 rounded-xl w-fit mb-6">
						<User class="w-8 h-8 text-primary" />
					</div>
					<h4 class="text-xl font-bold mb-4 font-serif">Deep Community Roots</h4>
					<p class="text-slate-500">Living and working in Macon County for [X] years has provided a firsthand look at our residents' needs.</p>
				</div>
				<div class="bg-white p-10 rounded-2xl shadow-sm border border-slate-100">
					<div class="bg-primary/5 p-4 rounded-xl w-fit mb-6">
						<Award class="w-8 h-8 text-primary" />
					</div>
					<h4 class="text-xl font-bold mb-4 font-serif">Proven Leadership</h4>
					<p class="text-slate-500">Decades of experience in [Professional Field] managing complex projects and diverse teams.</p>
				</div>
				<div class="bg-white p-10 rounded-2xl shadow-sm border border-slate-100">
					<div class="bg-primary/5 p-4 rounded-xl w-fit mb-6">
						<Heart class="w-8 h-8 text-primary" />
					</div>
					<h4 class="text-xl font-bold mb-4 font-serif">Community Servant</h4>
					<p class="text-slate-500">Actively involved in local [Non-profit/Civic] organizations to make a tangible difference.</p>
				</div>
			</div>
		</div>
	</section>
</Layout>
