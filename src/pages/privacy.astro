---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Privacy Policy | Russ Lunn for Macon County">
    <div class="pt-32 pb-20 bg-primary text-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h1 class="text-5xl md:text-7xl font-bold font-serif mb-6">Privacy Policy</h1>
            <p class="text-xl text-blue-50 max-w-3xl opacity-90 leading-relaxed uppercase tracking-widest font-bold">
                Protecting your data and trust.
            </p>
        </div>
    </div>

    <section class="py-24 bg-white">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="prose prose-lg text-slate-600 max-w-none">
                <p class="mb-8 italic text-slate-400">Last Updated: March 12, 2026</p>
                
                <h2 class="text-3xl font-bold text-slate-900 mb-6 font-serif">General Information</h2>
                <p class="mb-8">
                    The Committee to Elect Russ Lunn is committed to protecting your privacy. This Privacy Policy describes how we collect, use, and share information when you visit our website or interact with our campaign.
                </p>

                <h2 class="text-3xl font-bold text-slate-900 mb-6 font-serif">Information We Collect</h2>
                <h3 class="text-xl font-bold text-slate-800 mb-4">Personal Information</h3>
                <p class="mb-8">
                    We may collect personal information that you provide to us, such as your name, email address, phone number, and mailing address when you sign up for our newsletter, volunteer for our campaign, or make a donation.
                </p>

                <h3 class="text-xl font-bold text-slate-800 mb-4">Donation Information</h3>
                <p class="mb-8">
                    When you make a donation, we collect information required by the North Carolina State Board of Elections, including your occupation and employer. Financial transactions are processed securely through ActBlue, and we do not store your credit card information on our servers.
                </p>

                <h2 class="text-3xl font-bold text-slate-900 mb-6 font-serif">How We Use Your Information</h2>
                <p class="mb-8">
                    We use the information we collect to communicate with you about our campaign, process your donations, coordinate volunteer activities, and comply with legal reporting requirements. We do not sell or rent your personal information to third parties.
                </p>

                <h2 class="text-3xl font-bold text-slate-900 mb-6 font-serif">Opt-Out</h2>
                <p class="mb-8">
                    You may opt-out of receiving communications from us at any time by following the "unsubscribe" link in our emails or by contacting us at info@russlunn.org.
                </p>

                <h2 class="text-3xl font-bold text-slate-900 mb-6 font-serif">Changes to This Policy</h2>
                <p class="mb-8">
                    We may update this Privacy Policy from time to time. We will notify you of any changes by posting the new policy on this page and updating the "Last Updated" date.
                </p>
            </div>
        </div>
    </section>
</Layout>
