---
import Layout from "../layouts/Layout.astro";
import { Users, Mail, Phone, MapPin } from "@lucide/astro";
---

<Layout title="Volunteer | Russ Lunn for Macon County">
    <div class="pt-32 pb-20 bg-primary text-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h1 class="text-5xl md:text-7xl font-bold font-serif mb-6">Join the Team</h1>
            <p class="text-xl md:text-2xl text-blue-50 max-w-3xl mx-auto opacity-90 leading-relaxed">
                Russ can't do this alone. Your time and energy are what make this campaign move forward.
            </p>
        </div>
    </div>

    <section class="py-24 bg-white">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="bg-white rounded-3xl shadow-2xl border border-slate-100 overflow-hidden">
                <div class="p-10 md:p-16">
                    <h2 class="text-3xl font-bold text-slate-900 mb-8 font-serif">Volunteer Signup</h2>
                    <p class="text-slate-600 mb-12">Fill out the form below, and a team member will reach out to you shortly about how you can get involved.</p>
                    
                    <form 
                        name="volunteer-signup" 
                        method="POST" 
                        data-netlify="true" 
                        class="space-y-8"
                    >
                        <input type="hidden" name="form-name" value="volunteer-signup" />
                        
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            <div class="space-y-3">
                                <label for="first-name" class="block text-sm font-bold uppercase tracking-widest text-slate-700">First Name</label>
                                <input type="text" id="first-name" name="first-name" class="w-full px-5 py-4 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-accent transition-all" required placeholder="John" />
                            </div>
                            <div class="space-y-3">
                                <label for="last-name" class="block text-sm font-bold uppercase tracking-widest text-slate-700">Last Name</label>
                                <input type="text" id="last-name" name="last-name" class="w-full px-5 py-4 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-accent transition-all" required placeholder="Doe" />
                            </div>
                        </div>

                        <div class="space-y-3">
                            <label for="email" class="block text-sm font-bold uppercase tracking-widest text-slate-700">Email Address</label>
                            <input type="email" id="email" name="email" class="w-full px-5 py-4 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-accent transition-all" required placeholder="john@example.com" />
                        </div>

                        <div class="space-y-3">
                            <label class="block text-sm font-bold uppercase tracking-widest text-slate-700 mb-4">I'm interested in:</label>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <label class="flex items-center p-4 bg-slate-50 rounded-xl border border-slate-200 cursor-pointer hover:bg-slate-100 transition-colors">
                                    <input type="checkbox" name="interest-door-knocking" class="w-5 h-5 rounded border-slate-300 text-accent focus:ring-accent" />
                                    <span class="ml-3 text-slate-700 font-medium">Door Knocking</span>
                                </label>
                                <label class="flex items-center p-4 bg-slate-50 rounded-xl border border-slate-200 cursor-pointer hover:bg-slate-100 transition-colors">
                                    <input type="checkbox" name="interest-phone-banking" class="w-5 h-5 rounded border-slate-300 text-accent focus:ring-accent" />
                                    <span class="ml-3 text-slate-700 font-medium">Phone Banking</span>
                                </label>
                                <label class="flex items-center p-4 bg-slate-50 rounded-xl border border-slate-200 cursor-pointer hover:bg-slate-100 transition-colors">
                                    <input type="checkbox" name="interest-events" class="w-5 h-5 rounded border-slate-300 text-accent focus:ring-accent" />
                                    <span class="ml-3 text-slate-700 font-medium">Event Support</span>
                                </label>
                                <label class="flex items-center p-4 bg-slate-50 rounded-xl border border-slate-200 cursor-pointer hover:bg-slate-100 transition-colors">
                                    <input type="checkbox" name="interest-yard-signs" class="w-5 h-5 rounded border-slate-300 text-accent focus:ring-accent" />
                                    <span class="ml-3 text-slate-700 font-medium">Yard Signs</span>
                                </label>
                            </div>
                        </div>

                        <div class="space-y-3">
                            <label for="message" class="block text-sm font-bold uppercase tracking-widest text-slate-700">Any other way you'd like to help?</label>
                            <textarea id="message" name="message" rows="4" class="w-full px-5 py-4 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-accent transition-all" placeholder="Tell us more..."></textarea>
                        </div>

                        <button type="submit" class="w-full bg-accent hover:opacity-90 text-white font-bold py-6 rounded-xl text-xl shadow-xl transition-all transform hover:-translate-y-1 uppercase tracking-widest">
                            Submit Application
                        </button>
                    </form>

                    <p class="mt-8 text-center text-xs text-slate-400">
                        By submitting, you agree to receive campaign updates via email. You can opt-out at any time.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 bg-slate-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
                <div class="p-8">
                    <div class="bg-white p-6 rounded-full w-fit mx-auto mb-6 shadow-sm">
                        <Mail class="w-8 h-8 text-primary" />
                    </div>
                    <h3 class="text-xl font-bold mb-2 font-serif">Email Us</h3>
                    <p class="text-slate-500">info@russlunn.org</p>
                </div>
                <div class="p-8 border-y-2 md:border-y-0 md:border-x-2 border-slate-200">
                    <div class="bg-white p-6 rounded-full w-fit mx-auto mb-6 shadow-sm">
                        <Users class="w-8 h-8 text-primary" />
                    </div>
                    <h3 class="text-xl font-bold mb-2 font-serif">Follow Along</h3>
                    <p class="text-slate-500">@RussLunnForMacon</p>
                </div>
                <div class="p-8">
                    <div class="bg-white p-6 rounded-full w-fit mx-auto mb-6 shadow-sm">
                        <MapPin class="w-8 h-8 text-primary" />
                    </div>
                    <h3 class="text-xl font-bold mb-2 font-serif">Headquarters</h3>
                    <p class="text-slate-500">Franklin, NC 28734</p>
                </div>
            </div>
        </div>
    </section>
</Layout>
